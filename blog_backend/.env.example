# 数据库配置
BLOG_DATABASE_DSN=root:your_password@tcp(127.0.0.1:3306)/junblog?charset=utf8mb4&parseTime=True&loc=Local

# JWT 配置（secret 至少 32 字节随机字符串）
BLOG_JWT_SECRET=your_random_secret_key_at_least_32_bytes_here
BLOG_JWT_ISSUER=junblog
BLOG_JWT_ACCESS_EXPIRE=15
BLOG_JWT_REFRESH_EXPIRE=168

# MinIO 配置
BLOG_MINIO_ENDPOINT=127.0.0.1:9001
BLOG_MINIO_ACCESS_KEY=admin
BLOG_MINIO_SECRET_KEY=your_minio_secret
BLOG_MINIO_BUCKET=junblog
BLOG_MINIO_USE_SSL=false
BLOG_MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9001/junblog

# 服务器配置
BLOG_SERVER_PORT=:8080
BLOG_SERVER_MODE=debug
